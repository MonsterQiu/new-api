# Separate compose project names keep prod and preview isolated.
COMPOSE_PROJECT_NAME=new-api-prod

# Your own image tag. Do not use upstream calciumion/new-api here.
NEW_API_IMAGE=ghcr.io/your-account/new-api:ui-20260419-01

# App should stay local-only. Caddy is the public entrypoint.
APP_BIND_IP=127.0.0.1
APP_PORT=3000
FRONTEND_BASE_URL=https://api.sisyphusx.com
TZ=Asia/Shanghai

# Keep the existing server paths so migration stays simple.
APP_DATA_DIR=/data/one-api
MYSQL_DATA_DIR=/data/one-api/mysql

# Database and session config.
MYSQL_DATABASE=new-api
MYSQL_ROOT_PASSWORD=change-me
SQL_DSN=root:change-me@tcp(mysql:3306)/new-api?charset=utf8mb4&parseTime=true&loc=Local
SESSION_SECRET=replace-with-a-long-random-string

# Long-lived streaming works better with explicit timeouts.
RELAY_TIMEOUT=0
STREAMING_TIMEOUT=600
ERROR_LOG_ENABLED=true
BATCH_UPDATE_ENABLED=true
