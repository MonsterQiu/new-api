# Enterprise instance.
COMPOSE_PROJECT_NAME=new-api-ent

NEW_API_IMAGE=ghcr.io/your-account/new-api:ui-YYYYMMDD-SHORTSHA

# App should stay local-only. Caddy is the public entrypoint.
APP_BIND_IP=127.0.0.1
APP_PORT=3001
FRONTEND_BASE_URL=https://enterprise.example.com
TZ=Asia/Shanghai

# Independent data paths.
APP_DATA_DIR=/data/enterprise
MYSQL_DATA_DIR=/data/enterprise/mysql

# Independent database and session config.
MYSQL_DATABASE=enterprise
MYSQL_ROOT_PASSWORD=<set-at-deploy-time>
SQL_DSN=<db-user>:<db-password>@tcp(mysql:3306)/<db-name>?charset=utf8mb4&parseTime=true&loc=Local
SESSION_SECRET=<generate-32-byte-random-hex-at-deploy-time>

# Long-lived streaming works better with explicit timeouts.
RELAY_TIMEOUT=0
STREAMING_TIMEOUT=600
ERROR_LOG_ENABLED=true
BATCH_UPDATE_ENABLED=true

# Redis cache.
REDIS_PASSWORD=<set-redis-password-at-deploy-time>

# Optional home page branding. Empty values hide the corresponding sections.
HERO_ACCENT_ZH=
CONTACT_LABEL=
CONTACT_VALUE=
