COMPOSE_PROJECT_NAME=new-api-preview

NEW_API_IMAGE=ghcr.io/your-account/new-api:ui-20260419-01

APP_BIND_IP=127.0.0.1
APP_PORT=3001
FRONTEND_BASE_URL=https://beta-api.sisyphusx.com
TZ=Asia/Shanghai

APP_DATA_DIR=/data/new-api-preview
MYSQL_DATA_DIR=/data/new-api-preview/mysql

MYSQL_DATABASE=new-api-preview
MYSQL_ROOT_PASSWORD=<set-at-deploy-time>
SQL_DSN=<db-user>:<db-password>@tcp(mysql:3306)/<db-name>?charset=utf8mb4&parseTime=true&loc=Local
SESSION_SECRET=<generate-32-byte-random-hex-at-deploy-time>

RELAY_TIMEOUT=0
STREAMING_TIMEOUT=600
ERROR_LOG_ENABLED=true
BATCH_UPDATE_ENABLED=true
